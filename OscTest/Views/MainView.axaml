<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:OscVisualizer.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480"
			 x:Class="OscVisualizer.Views.MainView"
			 x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <StackPanel Margin="10" Spacing="10">
    <Border BorderBrush="Gray" BorderThickness="1" Margin="5">
      <TextBlock Text="Audio Visualization with OSC" FontSize="16" FontWeight="Bold" Margin="5"/>
    </Border>
    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10"
          RowDefinitions="Auto,Auto,Auto,Auto">
      <TextBlock Grid.Column="0" VerticalAlignment="Center">OSC Device:</TextBlock>
      <!-- 再生デバイス一覧 -->
      <ComboBox Grid.Column="1" Grid.Row="0"
                ItemsSource="{Binding PlaybackDevices}"
                SelectedItem="{Binding SelectedDevice}"
                HorizontalAlignment="Stretch"/>

      <!-- ボタン -->
      <Button Grid.Column="2" Grid.Row="0"
              Content="Update"
              Command="{Binding UpdateOutputDeviceList}" />

      <TextBlock Grid.Column="0" Grid.Row="1"
                 VerticalAlignment="Center">OSC Speed:</TextBlock>
      <Slider Grid.Column="1" Grid.Row="1"
              Minimum="0.01" Maximum="5"
              TickFrequency="0.01"
              SmallChange="0.01"
              Value="{Binding SpeedScale, Mode=TwoWay}"
              IsSnapToTickEnabled="True" />
      <TextBlock Grid.Column="2" Grid.Row="1"
                 Text="{Binding SpeedScale, StringFormat='F2'}"
                 VerticalAlignment="Center"/>

      <TextBlock Grid.Column="0" Grid.Row="2"
           VerticalAlignment="Center">OSC Settings:</TextBlock>
      <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="10">

        <CheckBox Content="Invert X" IsChecked="{Binding InvertX}" />
        <CheckBox Content="Invert Y" IsChecked="{Binding InvertY}" />

      </StackPanel>
      
      <TextBlock Grid.Column="0" Grid.Row="3"
                 VerticalAlignment="Center">Visualizer Type:</TextBlock>
      <ComboBox  Grid.Column="1" Grid.Row="3"
                 ItemsSource="{Binding VisualizerTypes}"
                SelectedItem="{Binding SelectedVisualizer}"
                DisplayMemberBinding="{Binding VisualizerName}"
                 HorizontalAlignment="Stretch"/>
    </Grid>

    <Grid ColumnDefinitions="Auto,Auto" HorizontalAlignment="Center">
      <Button Grid.Column="0"
        Content="Play"
              Command="{Binding StartVisualyzer}"/>
      <Button Grid.Column="1"
        Content="Stop"
              Command="{Binding Stop}"/>
    </Grid>
  </StackPanel>
</UserControl>
